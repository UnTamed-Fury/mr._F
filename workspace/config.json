{
  "goal": "Add type hints and improve docstrings for better code quality score",
  "max_iterations": 3,
  "mutation_style": "precise",
  "allow_refactor": true,
  "model": "nvidia/nemotron-3-super-120b-a12b:free",
  "fallback_model": "cognitivecomputations/dolphin-mistral-24b-venice-edition:free",
  "temperature": 0.3,
  "max_tokens": 4096,
  "max_lines_changed": 100,
  "use_critic": false,
  "use_reflection": false,
  "slow_mode": true,
  "timeout_seconds": 5,
  "max_file_size_multiplier": 2.0,
  "acceptance_threshold": 0.0,
  "summarize_every_n_runs": 10
}
